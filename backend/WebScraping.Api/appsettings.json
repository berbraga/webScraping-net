{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "webscraping"
  },
  "GooglePlaces": {
    "ApiKey": "",
    "UseFakeSource": true
  },
  "Search": {
    "DefaultMaxResults": 50,
    "AbsoluteMaxResults": 200
  },
  "Cors": {
    "Origins": [ "http://localhost:3000" ]
  },
  "Testing": {
    "UseInMemoryStores": false
  }
}
